# ClawVis Workspace — Environment
# Copy to .env and fill in values

# Chat backend — Ollama OpenAI-compatible API
HERMES_API_URL=http://localhost:11434
HERMES_DEFAULT_MODEL=gemma4:e4b

# Memory, sessions, tasks
HERMES_HOME=/root/MegaMaCluw/.claude/projects/-root-MegaMaCluw

# File browser root
HERMES_WORKSPACE_DIR=/root/MegaMaCluw/workspace

# Server
HOST=0.0.0.0
PORT=3001

# Security — set a strong random secret (32+ chars)
HERMES_PASSWORD=
TRUST_PROXY=1
COOKIE_SECURE=1
